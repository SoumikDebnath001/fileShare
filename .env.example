# Copy to ".env" on the Pi and fill in real values. Never commit the real .env.

# Required: the password you type on the login page.
FILESHARE_PASSWORD=change-this-to-a-strong-password

# Recommended: a long random string so login sessions survive restarts.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
FILESHARE_SECRET=

# Where uploaded files are stored. Use a path with plenty of space,
# e.g. a USB drive mounted at /mnt/usb.
FILESHARE_STORAGE=/home/pi/fileShare/storage

# Network. Keep host on 127.0.0.1 since nginx sits in front of the app.
FILESHARE_HOST=127.0.0.1
FILESHARE_PORT=8000

# Max size of a single uploaded file, in gigabytes.
FILESHARE_MAX_GB=8
